# Production build config — committed on purpose so CI release builds bake in
# the backend URL. NEXT_PUBLIC_* values are inlined into the client bundle and
# visible to anyone with the app, so nothing here is secret. Real secrets
# (e.g. the updater signing key) belong in GitHub Actions secrets / ~/.tauri.
NEXT_PUBLIC_API_BASE_URL=http://66.116.247.30:7100
NEXT_PUBLIC_USE_API=true
