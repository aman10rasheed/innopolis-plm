# Copy to `.env.local`. NEXT_PUBLIC_* vars are inlined at build time.

# Backend base URL (no trailing slash). Routes are served under /api,
# health under /health. Set this to the deployed backend host.
# e.g. https://plm-api.example.com   (dev default was http://localhost:7100)
NEXT_PUBLIC_API_BASE_URL=<your-backend-url>

# Toggle the data source:
#   true  → app talks to the real backend above (login hits POST /api/auth/login).
#           All screens are wired to the API; if the server is unreachable they
#           show a "Network issue" state rather than falling back to mock data.
#   false → legacy: app runs on the bundled mock database (offline demo).
NEXT_PUBLIC_USE_API=true
