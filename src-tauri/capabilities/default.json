{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the Innopolis main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://66.116.247.30:7100/*" },
        { "url": "http://localhost:7100/*" },
        { "url": "https://*/*" }
      ]
    }
  ]
}
